{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Config",
  "description": "Top-level configuration.",
  "type": "object",
  "properties": {
    "accessibility": {
      "description": "Accessibility settings — screen reader behavior, contrast, motion.",
      "$ref": "#/$defs/AccessibilityConfig",
      "default": {
        "announce_command_complete": true,
        "announce_exit_codes": true,
        "announce_images": true,
        "announce_pane_position": true,
        "announce_tab_details": true,
        "audio_command_complete": true,
        "audio_errors": true,
        "audio_feedback": false,
        "audio_progress": true,
        "high_contrast": "auto",
        "live_region_politeness": "polite",
        "min_contrast_ratio": 4.5,
        "output_debounce_ms": 100,
        "prompt_detection": "auto",
        "reduced_motion": "auto",
        "screen_reader_output": "auto"
      }
    },
    "colors": {
      "$ref": "#/$defs/ColorConfig",
      "default": {
        "background": "#0d0d14",
        "cursor": "#cccccc",
        "foreground": "#d9d9d9",
        "palette": [],
        "selection_bg": "#264f78",
        "theme": null
      }
    },
    "font": {
      "$ref": "#/$defs/FontConfig",
      "default": {
        "fallback_fonts": [
          "Segoe UI Emoji",
          "Segoe UI Symbol",
          "MS Gothic"
        ],
        "family": "Cascadia Code",
        "font_path": "",
        "ligatures": true,
        "line_height": 1.0,
        "size": 14.0
      }
    },
