    "Osc52Policy": {
      "description": "OSC 52 clipboard access policy.\n\nControls whether programs running in the terminal can read/write the system clipboard\nvia escape sequences. Write-only is the safe default — full read access could let a\nmalicious program silently exfiltrate clipboard contents.",
      "oneOf": [
        {
          "description": "Programs can write to clipboard but not read it.",
          "type": "string",
          "const": "write-only"
        },
        {
          "description": "Programs can both read and write clipboard.",
          "type": "string",
          "const": "read-write"
        },
        {
          "description": "Clipboard access via escape sequences is completely disabled.",
          "type": "string",
          "const": "disabled"
        }
      ]
    },
    "Padding": {
      "description": "Terminal content padding in pixels.\n\nSpace between the window edge and the terminal grid.\nA single value sets all four sides; otherwise specify individually.",
      "type": "object",
      "properties": {
        "bottom": {
          "description": "Padding on the bottom side in pixels.",
          "type": "integer",
          "format": "uint16",
          "default": 4,
          "maximum": 65535,
          "minimum": 0
        },
        "left": {
          "description": "Padding on the left side in pixels.",
          "type": "integer",
          "format": "uint16",
          "default": 4,
          "maximum": 65535,
          "minimum": 0
        },
        "right": {
          "description": "Padding on the right side in pixels.",
          "type": "integer",
          "format": "uint16",
          "default": 4,
          "maximum": 65535,
          "minimum": 0
        },
        "top": {
          "description": "Padding on the top side in pixels.",
          "type": "integer",
          "format": "uint16",
          "default": 4,
          "maximum": 65535,
          "minimum": 0
        }
      }
    },
    "Profile": {
      "description": "A named shell profile.",
      "type": "object",
      "properties": {
        "args": {
          "description": "Arguments to pass to the shell.",
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          }
        },
        "is_default": {
          "description": "Whether this is the default profile.",
          "type": "boolean",
          "default": false
        },
        "name": {
          "description": "Display name (e.g., \"PowerShell\", \"Command Prompt\").",
          "type": "string",
          "default": "Default"
        },
        "program": {
          "description": "Shell program to launch.",
          "type": "string",
          "default": ""
        },
        "working_directory": {
          "description": "Working directory (empty = inherit).",
          "type": "string",
          "default": ""
        }
      }
    },
    "PromptDetection": {
      "description": "Prompt detection strategy.",
      "oneOf": [
        {
          "description": "Use shell integration (OSC 133) if available, fall back to heuristic.",
          "type": "string",
          "const": "auto"
        },
        {
          "description": "Only use shell integration markers (OSC 133).",
          "type": "string",
          "const": "shell-integration"
        },
        {
          "description": "Only use heuristic regex patterns.",
          "type": "string",
          "const": "heuristic"
        },
        {
          "description": "Disable prompt detection entirely.",
          "type": "string",
          "const": "disabled"
        }
      ]
    },
    "ScreenReaderVerbosity": {
      "description": "Screen reader output verbosity level.",
      "oneOf": [
        {
          "description": "Detect screen reader presence and adjust automatically.",
          "type": "string",
          "const": "auto"
        },
        {
          "description": "Announce all terminal output (default for screen reader users).",
          "type": "string",
          "const": "all"
        },
        {
          "description": "Only announce command completions (prompt, exit code, summary).",
          "type": "string",
          "const": "commands-only"
        },
        {
          "description": "Only announce errors (non-zero exit codes, detected error lines).",
          "type": "string",
          "const": "errors-only"
        },
        {
          "description": "No automatic announcements — user navigates manually.",
          "type": "string",
          "const": "silent"
        }
      ]
    },
    "ScrollbarMode": {
      "description": "Scrollbar display mode.",
      "oneOf": [
        {
          "description": "Show scrollbar only when scrolled into history.",
          "type": "string",
          "const": "auto"
        },
        {
          "description": "Always show the scrollbar.",
          "type": "string",
          "const": "always"
        },
        {
          "description": "Never show the scrollbar.",
          "type": "string",
          "const": "never"
        }
      ]
    },
    "ShellConfig": {
      "description": "Shell configuration.",
      "type": "object",
      "properties": {
        "args": {
          "description": "Arguments to pass to the shell.",
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          }
        },
        "program": {
          "description": "Shell program to launch (empty = auto-detect).",
          "type": "string",
          "default": ""
        },
        "working_directory": {
          "description": "Working directory (empty = inherit).",
          "type": "string",
          "default": ""
        }
      }
    },
    "SshTarget": {
      "description": "An SSH connection target stored in the config.",
      "type": "object",
      "properties": {
        "extra_args": {
          "description": "Additional ssh arguments (e.g., [\"-o\", \"StrictHostKeyChecking=no\"]).",
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          }
        },
        "host": {
          "description": "Remote host (hostname or IP).",
          "type": "string",
          "default": ""
        },
        "identity_file": {
          "description": "Path to an identity/key file (empty = default).",
          "type": "string",
          "default": ""
        },
        "name": {
          "description": "Display name for this connection (e.g., \"Production Server\").",
          "type": "string",
          "default": ""
        },
        "port": {
          "description": "SSH port (default 22).",
          "type": "integer",
          "format": "uint16",
          "default": 22,
          "maximum": 65535,
          "minimum": 0
        },
        "user": {
          "description": "Username on the remote host (empty = current user).",
          "type": "string",
          "default": ""
        }
      }
    },
    "TabBarMode": {
      "description": "Tab bar display mode.",
      "oneOf": [
        {
          "description": "Show tab bar only when there are 2+ tabs.",
          "type": "string",
          "const": "auto-hide"
        },
        {
          "description": "Always show the tab bar.",
          "type": "string",
          "const": "always"
        },
        {
          "description": "Never show the tab bar.",
          "type": "string",
          "const": "never"
        }
      ]
    },
    "TerminalConfig": {
      "description": "Terminal behavior configuration.",
      "type": "object",
      "properties": {
        "bell": {
          "description": "Bell style: \"audible\", \"visual\", \"both\", or \"none\".",
          "$ref": "#/$defs/BellStyle",
          "default": "both"
        },
        "command_notify_threshold": {
          "description": "Notify when a command finishes after running for at least this many seconds\nand the window is not focused. 0 disables the notification.",
          "type": "integer",
          "format": "uint64",
          "default": 10,
          "minimum": 0
        },
        "cursor_blink": {
          "description": "Whether the cursor blinks.",
          "type": "boolean",
          "default": true
        },
        "cursor_blink_ms": {
          "description": "Cursor blink interval in milliseconds.",
          "type": "integer",
          "format": "uint64",
          "default": 530,
          "minimum": 0
        },
        "cursor_style": {
          "description": "Cursor style: \"block\", \"underline\", or \"bar\".",
          "type": "string",
          "default": "block"
        },
        "osc52": {
          "description": "OSC 52 clipboard access policy: \"write-only\" (default), \"read-write\", or \"disabled\".",
          "$ref": "#/$defs/Osc52Policy",
          "default": "write-only"
        },
        "scrollback_lines": {
          "description": "Maximum scrollback lines (0 = infinite).",
          "type": "integer",
          "format": "uint",
          "default": 0,
          "minimum": 0
        },
        "session_restore": {
          "description": "Session restore mode: \"never\" (default), \"always\", or \"ask\".",
          "type": "string",
          "default": ""
        }
      }
    },
    "WindowConfig": {
      "description": "Window configuration.",
      "type": "object",
      "properties": {
        "background": {
          "description": "Window background style: \"opaque\", \"acrylic\", or \"mica\".",
          "$ref": "#/$defs/BackgroundStyle",
          "default": "opaque"
        },
        "background_image": {
          "description": "Path to a background image (empty = none). Supports PNG, JPEG, GIF.",
          "type": "string",
          "default": ""
        },
        "background_image_opacity": {
          "description": "Background image opacity (0.0 = invisible, 1.0 = fully opaque). Default 0.3.",
          "type": "number",
          "format": "float",
          "default": 0.30000001192092896
        },
        "dark_title_bar": {
          "description": "Use dark title bar decoration.",
          "type": "boolean",
          "default": true
        },
        "height": {
          "description": "Initial window height in pixels.",
          "type": "integer",
          "format": "uint32",
          "default": 768,
          "minimum": 0
        },
        "opacity": {
          "description": "Window opacity (0.0 = fully transparent, 1.0 = fully opaque).",
          "type": "number",
          "format": "float",
          "default": 1.0
        },
        "padding": {
          "description": "Terminal content padding in pixels.",
          "$ref": "#/$defs/Padding",
          "default": {
            "bottom": 4,
            "left": 4,
            "right": 4,
            "top": 4
          }
        },
        "quake_hotkey": {
          "description": "Quake-mode global hotkey (e.g., \"win+backtick\"). Default: \"win+backtick\".",
          "type": "string",
          "default": "win+backtick"
        },
        "quake_mode": {
          "description": "Enable quake-mode: a global hotkey toggles the terminal window.",
          "type": "boolean",
          "default": false
        },
        "renderer": {
          "description": "Renderer: \"auto\", \"gpu\", or \"software\".",
          "type": "string",
          "default": "auto"
        },
        "scrollbar": {
          "description": "Scrollbar display mode: \"auto\" (when scrolled), \"always\", or \"never\".",
          "$ref": "#/$defs/ScrollbarMode",
          "default": "auto"
        },
        "tab_bar": {
          "description": "Tab bar display mode: \"auto-hide\" (2+ tabs), \"always\", or \"never\".",
          "$ref": "#/$defs/TabBarMode",
          "default": "auto-hide"
        },
        "title": {
          "description": "Window title.",
          "type": "string",
          "default": "Wixen Terminal"
        },
        "width": {
          "description": "Initial window width in pixels.",
          "type": "integer",
          "format": "uint32",
          "default": 1024,
          "minimum": 0
        }
      }
    }
  }
}