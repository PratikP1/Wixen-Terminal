    "profiles": {
      "description": "Named shell profiles. If empty, a single profile is synthesized from `[shell]`.",
      "type": "array",
      "default": [],
      "items": {
        "$ref": "#/$defs/Profile"
      }
    },
    "shell": {
      "$ref": "#/$defs/ShellConfig",
      "default": {
        "args": [],
        "program": "",
        "working_directory": ""
      }
    },
    "ssh": {
      "description": "SSH connection targets.",
      "type": "array",
      "default": [],
      "items": {
        "$ref": "#/$defs/SshTarget"
      }
    },
    "terminal": {
      "$ref": "#/$defs/TerminalConfig",
      "default": {
        "bell": "both",
        "command_notify_threshold": 10,
        "cursor_blink": true,
        "cursor_blink_ms": 530,
        "cursor_style": "block",
        "osc52": "write-only",
        "scrollback_lines": 0,
        "session_restore": "never"
      }
    },
    "window": {
      "$ref": "#/$defs/WindowConfig",
      "default": {
        "background": "opaque",
        "background_image": "",
        "background_image_opacity": 0.30000001192092896,
        "dark_title_bar": true,
        "height": 768,
        "opacity": 1.0,
        "padding": {
          "bottom": 4,
          "left": 4,
          "right": 4,
          "top": 4
        },
        "quake_hotkey": "win+backtick",
        "quake_mode": false,
        "renderer": "auto",
        "scrollbar": "auto",
        "tab_bar": "auto-hide",
        "title": "Wixen Terminal",
        "width": 1024
      }
    }
  },
  "$defs": {
    "AccessibilityConfig": {
      "description": "Accessibility configuration.\n\nControls screen reader behavior, contrast enforcement, and motion\npreferences. All settings have sensible defaults — screen reader users\nget a good experience without editing config.",
      "type": "object",
      "properties": {
        "announce_command_complete": {
          "description": "Announce when a command finishes (includes exit code and line count).",
          "type": "boolean",
          "default": true
        },
        "announce_exit_codes": {
          "description": "Include exit codes in command completion announcements.",
          "type": "boolean",
          "default": true
        },
        "announce_images": {
          "description": "Announce inline images when placed (Sixel, iTerm2, Kitty).",
          "type": "boolean",
          "default": true
        },
        "announce_pane_position": {
          "description": "Announce pane position when switching (e.g., \"Left pane, 1 of 3\").",
          "type": "boolean",
          "default": true
        },
        "announce_tab_details": {
          "description": "Announce tab details when switching (shell type, cwd, status).",
          "type": "boolean",
          "default": true
        },
        "audio_command_complete": {
          "description": "Enable audio tone specifically for command completion.",
          "type": "boolean",
          "default": true
        },
        "audio_errors": {
          "description": "Enable audio tone specifically for error/warning detection.",
          "type": "boolean",
          "default": true
        },
        "audio_feedback": {
          "description": "Enable audio feedback tones (beeps) for terminal events.\n\nWhen true, the terminal plays short tones for command completion,\nerrors, progress updates, and mode changes. Works independently\nof screen readers — useful for any user who wants audio cues.",
          "type": "boolean",
          "default": false
        },
        "audio_progress": {
          "description": "Enable audio tone specifically for progress bar updates.",
          "type": "boolean",
          "default": true
        },
        "high_contrast": {
          "description": "High contrast mode: `\"auto\"` follows Windows system setting.",
          "type": "string",
          "default": "auto"
        },
        "live_region_politeness": {
          "description": "UIA live region politeness for output announcements.\n\n`\"polite\"` queues behind current speech; `\"assertive\"` interrupts.",
          "type": "string",
          "default": "polite"
        },
        "min_contrast_ratio": {
          "description": "Minimum foreground/background contrast ratio (WCAG AA = 4.5).\n\nWhen terminal programs set colors below this threshold, Wixen\nadjusts the color to meet it. Set to 0.0 to disable.",
          "type": "number",
          "format": "float",
          "default": 4.5
        },
        "output_debounce_ms": {
          "description": "Milliseconds between screen reader output announcements.\n\nControls how often batched terminal output is sent to the screen reader.\nLower values feel more responsive but can overwhelm speech; higher values\ngive a pause between chunks so users can follow along. Range: 50–1000.",
          "type": "integer",
          "format": "uint32",
          "default": 100,
          "minimum": 0
        },
        "prompt_detection": {
          "description": "How prompts are detected for command block structure.",
          "$ref": "#/$defs/PromptDetection",
          "default": "auto"
        },
        "reduced_motion": {
          "description": "Reduced motion: `\"auto\"` follows Windows system setting.\n\nWhen active, disables cursor blink, visual bell flash, and\nsmooth scrolling animations.",
          "type": "string",
          "default": "auto"
        },
        "screen_reader_output": {
          "description": "How much terminal output the screen reader announces.",
          "$ref": "#/$defs/ScreenReaderVerbosity",
          "default": "auto"
        }
      }
    },
    "BackgroundStyle": {
      "description": "Window background style.",
      "oneOf": [
        {
          "description": "Standard opaque background.",
          "type": "string",
          "const": "opaque"
        },
        {
          "description": "Acrylic blur (Windows 11 22H2+).",
          "type": "string",
          "const": "acrylic"
        },
        {
          "description": "Mica material (Windows 11 22H2+).",
          "type": "string",
          "const": "mica"
        }
      ]
    },
    "BellStyle": {
      "description": "Bell notification style.",
      "oneOf": [
        {
          "description": "Play a system sound.",
          "type": "string",
          "const": "audible"
        },
        {
          "description": "Flash the window/taskbar.",
          "type": "string",
          "const": "visual"
        },
        {
          "description": "Both sound and flash.",
          "type": "string",
          "const": "both"
        },
        {
          "description": "No bell notification.",
          "type": "string",
          "const": "none"
        }
      ]
    },
    "ColorConfig": {
      "description": "Color scheme configuration.",
      "type": "object",
      "properties": {
        "background": {
          "description": "Background color as hex (e.g., \"#0d0d14\").",
          "type": "string",
          "default": "#0d0d14"
        },
        "cursor": {
          "description": "Cursor color as hex.",
          "type": "string",
          "default": "#cccccc"
        },
        "foreground": {
          "description": "Foreground color as hex (e.g., \"#d9d9d9\").",
          "type": "string",
          "default": "#d9d9d9"
        },
        "palette": {
          "description": "ANSI 16-color palette overrides (indexed 0-15).",
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          }
        },
        "selection_bg": {
          "description": "Selection background color as hex.",
          "type": "string",
          "default": "#264f78"
        },
        "theme": {
          "description": "Built-in theme name (e.g., \"dracula\", \"catppuccin-mocha\").\nIf set, provides base colors; individual fields below override the theme.",
          "type": [
            "string",
            "null"
          ],
          "default": null
        }
      }
    },
    "FontConfig": {
      "description": "Font configuration.",
      "type": "object",
      "properties": {
        "fallback_fonts": {
          "description": "Fallback font families tried when the primary font lacks a glyph.",
          "type": "array",
          "default": [
            "Segoe UI Emoji",
            "Segoe UI Symbol",
            "MS Gothic"
          ],
          "items": {
            "type": "string"
          }
        },
        "family": {
          "description": "Font family name (DirectWrite lookup).",
          "type": "string",
          "default": "Cascadia Code"
        },
        "font_path": {
          "description": "Path to a font file (.ttf/.otf) to load directly instead of by family name.\n\nWhen non-empty, this takes priority over `family`.",
          "type": "string",
          "default": ""
        },
        "ligatures": {
          "description": "Enable programming ligatures (e.g., =>, ->, != in Fira Code / Cascadia Code).",
          "type": "boolean",
          "default": true
        },
        "line_height": {
          "description": "Line height multiplier (1.0 = tight, 1.2 = comfortable).",
          "type": "number",
          "format": "float",
          "default": 1.0
        },
        "size": {
          "description": "Font size in points.",
          "type": "number",
          "format": "float",
          "default": 14.0
        }
      }
    },
    "Keybinding": {
      "description": "A single keybinding entry.",
      "type": "object",
      "properties": {
        "action": {
          "description": "Action identifier, e.g. \"new_tab\", \"close_tab\", \"send_text\".",
          "type": "string"
        },
        "args": {
          "description": "Optional argument for the action (e.g., the text to send for \"send_text\").\n\nSupports escape sequences: `\\n` (LF), `\\r` (CR), `\\t` (tab), `\\x1b` (ESC),\n`\\\\` (backslash).",
          "type": [
            "string",
            "null"
          ]
        },
        "chord": {
          "description": "Key chord string, normalized: lowercase, modifiers sorted alphabetically.\nExample: \"ctrl+shift+t\"",
          "type": "string"
        }
      },
      "required": [
        "chord",
        "action"
      ]
    },
